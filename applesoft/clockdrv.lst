0003E9r 2               .I16
0003E9r 2  48           	pha
0003EAr 2  48           	pha
0003EBr 2  48           	pha
0003ECr 2  48           	pha
0003EDr 2  A2 03 0D     	ldx #$0D03
0003F0r 2  22 00 00 E1  	jsl $E10000
0003F4r 2  E2 30        	sep #$30
0003F6r 2               .I8
0003F6r 2  A2 07        	ldx #7
0003F8r 2               GTGSLoop:
0003F8r 2  68           	pla
