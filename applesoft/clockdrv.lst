000211r 2  20 rr rr     	jsr DCdbgPrRaw2
000214r 2  20 rr rr     	jsr DClockValidTime
000217r 2  B0 34        	bcs DCdbgFail
000219r 2  20 rr rr     	jsr DCdbgFillTimeNow
00021Cr 2  A0 00        	ldy #$00
00021Er 2               @binLbl:
00021Er 2  B9 rr rr     	lda DCdBin,y
000221r 2  F0 06        	beq @binDone
000223r 2  20 ED FD     	jsr COUT1
000226r 2  C8           	iny
000227r 2  D0 F5        	bne @binLbl
000229r 2               @binDone:
000229r 2  A2 00        	ldx #$00
00022Br 2               @tLp:
00022Br 2  BD rr rr     	lda TimeNow,x
00022Er 2  20 DA FD     	jsr PRBYTE
000231r 2  A9 A0        	lda #$a0
000233r 2  20 ED FD     	jsr COUT1
000236r 2  E8           	inx
000237r 2  E0 04        	cpx #$04
000239r 2  90 F0        	bcc @tLp
00023Br 2  A0 00        	ldy #$00
00023Dr 2               @dnLp:
00023Dr 2  B9 rr rr     	lda DCdDone,y
000240r 2  F0 06        	beq DCdbgExitOk
000242r 2  20 ED FD     	jsr COUT1
000245r 2  C8           	iny
000246r 2  D0 F5        	bne @dnLp
000248r 2               DCdbgExitOk:
000248r 2  20 8E FD     	jsr CROUT
00024Br 2  18           	clc
