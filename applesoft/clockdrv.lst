000257r 2  C8           	iny
000258r 2  D0 F5        	bne :-
00025Ar 2  20 8E FD     :	jsr CROUT
00025Dr 2  38           	sec
00025Er 2  60           	rts
00025Fr 2               
00025Fr 2               DCdbgPrRaw1:
00025Fr 2  A0 00        	ldy #$00
000261r 2               @r1:
000261r 2  B9 rr rr     	lda DCdR1,y
000264r 2  F0 13        	beq DCdbgPr8
000266r 2  20 ED FD     	jsr COUT1
000269r 2  C8           	iny
00026Ar 2  D0 F5        	bne @r1
00026Cr 2               DCdbgPrRaw2:
00026Cr 2  A0 00        	ldy #$00
00026Er 2               @r2:
00026Er 2  B9 rr rr     	lda DCdR2,y
000271r 2  F0 06        	beq DCdbgPr8
000273r 2  20 ED FD     	jsr COUT1
000276r 2  C8           	iny
000277r 2  D0 F5        	bne @r2
000279r 2               DCdbgPr8:
000279r 2  A0 00        	ldy #$00
00027Br 2               @p8:
00027Br 2  B9 rr rr     	lda DCBuf,y
