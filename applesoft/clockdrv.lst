0003CEr 2  20 rr rr     	jsr L701B
0003D1r 2  A9 08        	lda #$08
0003D3r 2  20 rr rr     	jsr L701B
0003D6r 2  A2 0A        	ldx #$0A
0003D8r 2  20 rr rr     L7011:	jsr L7033
0003DBr 2  9D rr rr     	sta L7069,x
0003DEr 2  CA           	dex
0003DFr 2  D0 F7        	bne L7011
0003E1r 2  18           	clc		; Convert from BCD and copy out time
0003E2r 2  AD rr rr     	lda TKH1	; Multiply 10s of hours by 10, add to units
0003E5r 2  A2 0A        	ldx #$0a
0003E7r 2  6D rr rr     :	adc TKH2
0003EAr 2  CA           	dex
0003EBr 2  D0 FA        	bne :-
0003EDr 2  AD rr rr     	lda TKH2	; Hours
0003F0r 2  8D rr rr     	sta TimeNow
0003F3r 2  18           	clc
0003F4r 2  AD rr rr     	lda TKM1	; Multiply 10s of minutes by 10, add to units
0003F7r 2  A2 0A        	ldx #$0a
0003F9r 2  6D rr rr     :	adc TKM2
0003FCr 2  CA           	dex
0003FDr 2  D0 FA        	bne :-
0003FFr 2  AD rr rr     	lda TKM2	; Minutes
000402r 2  8D rr rr     	sta TimeNow+1
000405r 2  18           	clc
000406r 2  AD rr rr     	lda TKS1	; Multiply 10s of seconds by 10, add to units
000409r 2  A2 0A        	ldx #$0a
00040Br 2  6D rr rr     :	adc TKS2
00040Er 2  CA           	dex
00040Fr 2  D0 FA        	bne :-
000411r 2  AD rr rr     	lda TKS2	; Seconds
000414r 2  8D rr rr     	sta TimeNow+2
000417r 2  A9 00        	lda #$00	; Hundredths (not available on Thunderclock)
000419r 2  8D rr rr     	sta TimeNow+3
