0003C4r 2               GetTimeThunderclock:
0003C4r 2               ;---------------------------------------------------------
0003C4r 2               ; Get the current time from a Thunderclock - and convert from BCD
0003C4r 2               ;---------------------------------------------------------
0003C4r 2  AD rr rr     	lda ClockSlot
0003C7r 2  0A           	asl a
0003C8r 2  0A           	asl a
0003C9r 2  0A           	asl a
