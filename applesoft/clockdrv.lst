0001F6r 2  20 rr rr     	jsr DCdbgPrRaw1
0001F9r 2  20 rr rr     	jsr DClockValidTime
0001FCr 2  B0 4F        	bcs DCdbgFail
0001FEr 2  A0 00        	ldy #$00
