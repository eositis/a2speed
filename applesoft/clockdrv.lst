000000r 1               ; A2SPEED clock driver for Applesoft (ProDOS/BASIC.SYSTEM)
000000r 1               ; Safer wrapper around SPF gettime routines.
000000r 1               ;
000000r 1               ; Entry points (load at $7000; see clockdrv.lst/map):
000000r 1               ;   $7000 CLOCK_INIT  - detect/select backend (no self-modifying GetTime vector)
000000r 1               ;   $7059 CLOCK_READ  - sample selected backend into TimeNow (see clockdrv.lst; sync A2SPEED.bas)
000000r 1               ;
000000r 1               ; Detection priority (first match wins):
000000r 1               ;   1 IIgs   2 ROMX   3 MegaFlash   4 No-Slot Clock
000000r 1               ;   5 TimeMaster II H.O. (slot ROM id $4D/$D9 at Cn00-01; AE ROM Rev 5)
000000r 1               ; Thunderclock is not selected: 1 s resolution is too coarse for A2Speed wall timing.
000000r 1               ; TimeMaster read still uses SPF GetTimeThunderclock (BCD slot path; name is historical).
000000r 1               
000000r 1                       UTILPTR = $07
000000r 1               
000000r 1                       KIND_NONE   = 0
000000r 1                       KIND_GS     = 1
000000r 1                       KIND_ROMX   = 2
000000r 1                       KIND_MEGA   = 3
000000r 1                       KIND_NSC    = 4
000000r 1                       KIND_TM     = 5
000000r 1               
000000r 1                       .segment "CODE"
000000r 1                       .export CLOCK_KIND, TimeNow, ClockSlot
000000r 1               
000000r 1               ; SPF gettime.asm (DClock): machine ID + monitor I/O + scratch (not in stock SPF for ca65).
000000r 1               VERSION         = $FBB3
000000r 1               CROUT           = $FD8E
000000r 1               COUT1           = $FDED
000000r 1               PRBYTE          = $FDDA
000000r 1               
000000r 1  xx xx xx xx  DCBuf:          .res    8
000004r 1  xx xx xx xx  
000008r 1  xx           DCPreserve:     .res    1
000009r 1  xx           DCW8Byte:       .res    1
00000Ar 1  xx           DCBcdScratch:   .res    1
00000Br 1               
00000Br 1               CLOCK_INIT:
00000Br 1  20 rr rr             jsr     SaveZP
00000Er 1  A9 00                lda     #KIND_NONE
000010r 1  8D rr rr             sta     CLOCK_KIND
000013r 1               
000013r 1                       ; IIgs
000013r 1  38                   sec
000014r 1  20 1F FE             jsr     $FE1F
000017r 1  B0 08                bcs     @chk_romx
000019r 1  A9 01                lda     #KIND_GS
00001Br 1  8D rr rr             sta     CLOCK_KIND
00001Er 1  4C rr rr             jmp     @done_init
000021r 1               
000021r 1               @chk_romx:
000021r 1  20 rr rr             jsr     CheckForROMX
000024r 1  B0 08                bcs     @chk_mega
000026r 1  A9 02                lda     #KIND_ROMX
000028r 1  8D rr rr             sta     CLOCK_KIND
00002Br 1  4C rr rr             jmp     @done_init
00002Er 1               
00002Er 1               @chk_mega:
00002Er 1  20 rr rr             jsr     CheckForMegaFlash
000031r 1  B0 08                bcs     @chk_nsc
000033r 1  A9 03                lda     #KIND_MEGA
000035r 1  8D rr rr             sta     CLOCK_KIND
000038r 1  4C rr rr             jmp     @done_init
00003Br 1               
00003Br 1               @chk_nsc:
00003Br 1  20 rr rr             jsr     CheckForNoSlotClock
00003Er 1  B0 08                bcs     @chk_tm
000040r 1  A9 04                lda     #KIND_NSC
000042r 1  8D rr rr             sta     CLOCK_KIND
000045r 1  4C rr rr             jmp     @done_init
000048r 1               
000048r 1               @chk_tm:
000048r 1  20 rr rr             jsr     CheckForTimeMaster
00004Br 1  B0 08                bcs     @done_init
00004Dr 1  A9 05                lda     #KIND_TM
00004Fr 1  8D rr rr             sta     CLOCK_KIND
000052r 1  4C rr rr             jmp     @done_init
000055r 1               
000055r 1               @done_init:
000055r 1  20 rr rr             jsr     RestoreZP
000058r 1  60                   rts
000059r 1               
000059r 1               CLOCK_READ:
000059r 1  20 rr rr             jsr     SaveZP
00005Cr 1  AD rr rr             lda     CLOCK_KIND
00005Fr 1  C9 01                cmp     #KIND_GS
000061r 1  D0 06                bne     @r2
000063r 1  20 rr rr             jsr     GetTimeGS
000066r 1  4C rr rr             jmp     @done_read
000069r 1               @r2:
000069r 1  C9 02                cmp     #KIND_ROMX
00006Br 1  D0 06                bne     @r3
00006Dr 1  20 rr rr             jsr     GetTimeROMX
000070r 1  4C rr rr             jmp     @done_read
000073r 1               @r3:
000073r 1  C9 03                cmp     #KIND_MEGA
000075r 1  D0 06                bne     @r4
000077r 1  20 rr rr             jsr     GetTimeMegaFlashA2
00007Ar 1  4C rr rr             jmp     @done_read
00007Dr 1               @r4:
00007Dr 1  C9 04                cmp     #KIND_NSC
00007Fr 1  D0 06                bne     @r5
000081r 1  20 rr rr             jsr     GetTimeNSC
000084r 1  4C rr rr             jmp     @done_read
000087r 1               @r5:
000087r 1  C9 05                cmp     #KIND_TM
000089r 1  D0 06                bne     @done_read
00008Br 1  20 rr rr             jsr     GetTimeTimeMaster
00008Er 1  4C rr rr             jmp     @done_read
000091r 1               
000091r 1               @done_read:
000091r 1  20 rr rr             jsr     RestoreZP
000094r 1  60                   rts
000095r 1               
000095r 1               GetTimeTimeMaster:
000095r 1  4C rr rr             jmp     GetTimeThunderclock
000098r 1               
000098r 1               SaveZP:
000098r 1  A2 00                ldx     #$00
00009Ar 1               @sloop:
00009Ar 1  B5 00                lda     $00,x
00009Cr 1  9D rr rr             sta     ZPSAVE,x
00009Fr 1  E8                   inx
0000A0r 1  D0 F8                bne     @sloop
0000A2r 1  60                   rts
0000A3r 1               
0000A3r 1               RestoreZP:
0000A3r 1  A2 00                ldx     #$00
0000A5r 1               @rloop:
0000A5r 1  BD rr rr             lda     ZPSAVE,x
0000A8r 1  95 00                sta     $00,x
0000AAr 1  E8                   inx
0000ABr 1  D0 F8                bne     @rloop
0000ADr 1  60                   rts
0000AEr 1               
0000AEr 1               ; Applied Engineering TimeMaster II H.O. — ROM id at Cn00-01 ($4D $D9), not Thunder $08 $78 $28.
0000AEr 1               CheckForTimeMaster:
0000AEr 1  38                   sec
0000AFr 1  A2 07                ldx     #$07
0000B1r 1               @tmloop:
0000B1r 1  18                   clc
0000B2r 1  8A                   txa
0000B3r 1  69 C0                adc     #$c0
0000B5r 1  85 08                sta     UTILPTR+1
0000B7r 1  A9 00                lda     #$00
0000B9r 1  85 07                sta     UTILPTR
0000BBr 1  A0 00                ldy     #$00
0000BDr 1  B1 07                lda     (UTILPTR),y
0000BFr 1  C9 4D                cmp     #$4D
0000C1r 1  D0 0C                bne     @tmnext
0000C3r 1  C8                   iny
0000C4r 1  B1 07                lda     (UTILPTR),y
0000C6r 1  C9 D9                cmp     #$D9
0000C8r 1  D0 05                bne     @tmnext
0000CAr 1  8E rr rr             stx     ClockSlot
0000CDr 1  18                   clc
0000CEr 1  60                   rts
0000CFr 1               @tmnext:
0000CFr 1  CA                   dex
0000D0r 1  D0 DF                bne     @tmloop
0000D2r 1  38                   sec
0000D3r 1  60                   rts
0000D4r 1               
0000D4r 1                       .include "gettime.asm"
