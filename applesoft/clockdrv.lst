0003B8r 2               PrepThunderclock:
0003B8r 2               ;---------------------------------------------------------
0003B8r 2               ; Patch the entry point of GetTime to the Thunderclock version
0003B8r 2               ;---------------------------------------------------------
0003B8r 2  A9 rr        	lda #<GetTimeThunderclock
0003BAr 2  8D rr rr     	sta GetTime+1
0003BDr 2  A9 rr        	lda #>GetTimeThunderclock
0003BFr 2  8D rr rr     	sta GetTime+2
0003C2r 2  60           	rts
0003C3r 2               
0003C3r 2  60           	rts
