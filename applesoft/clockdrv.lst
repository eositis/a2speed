000657r 2               CheckForSlottedClocks:
000657r 2               ;---------------------------------------------------------
000657r 2               ; Look for clocks via signature in firmware
000657r 2               ;---------------------------------------------------------
000657r 2  38           	sec
000658r 2               FindClockSlot:
000658r 2  A9 00        	lda #$00
00065Ar 2  A8           	tay
00065Br 2  85 07        	sta UTILPTR
00065Dr 2  8D rr rr     	sta ClockSlot
000660r 2  A2 07        	ldx #$07 ; Slot number
000662r 2               FindClockSlotLoop:
000662r 2  18           	clc
000663r 2  8A           	txa
000664r 2  69 C0        	adc #$c0
000666r 2  85 08        	sta UTILPTR+1
000668r 2  A0 00        	ldy #$00		; Lookup offset
00066Ar 2  B1 07        	lda (UTILPTR),y
00066Cr 2  C9 08        	cmp #$08		; Is $Cn00 == $08?
00066Er 2  D0 17        	bne NotThunder
000670r 2  C8           	iny			; Lookup offset
000671r 2  B1 07        	lda (UTILPTR),y
000673r 2  C9 78        	cmp #$78		; Is $Cn01 == $78?
000675r 2  D0 10        	bne NotThunder
000677r 2  C8           	iny			; Lookup offset
000678r 2  B1 07        	lda (UTILPTR),y
00067Ar 2  C9 28        	cmp #$28		; Is $Cn02 == $28?
00067Cr 2  D0 09        	bne NotThunder
00067Er 2               ; Ok, we have a set of signature bytes for a Thunderclock.
00067Er 2  8E rr rr     	stx ClockSlot
000681r 2  20 rr rr     	jsr PrepThunderclock
000684r 2  4C rr rr     	jmp FindClockSlotDone
000687r 2               NotThunder:
000687r 2               	; Check for other slotted clocks
000687r 2               FindClockSlotNext:
000687r 2  CA           	dex
000688r 2  D0 D8        	bne FindClockSlotLoop
00068Ar 2               ; All done now, return with carry clear if we found a clock
00068Ar 2               FindClockSlotDone:
00068Ar 2  38           	sec
00068Br 2  AD rr rr     	lda ClockSlot
00068Er 2  F0 01        	beq :+
000690r 2  18           	clc
000691r 2  60           :	rts
000692r 2  00           ClockSlot:	.byte 0
000693r 2               
000693r 2               PrepThunderclock:
000693r 2               ;---------------------------------------------------------
000693r 2               ; Patch the entry point of GetTime to the Thunderclock version
000693r 2               ;---------------------------------------------------------
000693r 2  A9 rr        	lda #<GetTimeThunderclock
000695r 2  8D rr rr     	sta GetTime+1
000698r 2  A9 rr        	lda #>GetTimeThunderclock
00069Ar 2  8D rr rr     	sta GetTime+2
00069Dr 2  60           	rts
00069Er 2               
00069Er 2  60           	rts
00069Fr 2               
00069Fr 2               
00069Fr 2               GetTimeThunderclock:
00069Fr 2               ;---------------------------------------------------------
00069Fr 2               ; Get the current time from a Thunderclock - and convert from BCD
00069Fr 2               ;---------------------------------------------------------
00069Fr 2  AD rr rr     	lda ClockSlot
0006A2r 2  0A           	asl a
0006A3r 2  0A           	asl a
0006A4r 2  0A           	asl a
0006A5r 2  0A           	asl a
0006A6r 2  A8           	tay
0006A7r 2  A9 18        	lda #$18
0006A9r 2  20 rr rr     	jsr L701B
0006ACr 2  A9 08        	lda #$08
0006AEr 2  20 rr rr     	jsr L701B
0006B1r 2  A2 0A        	ldx #$0A
0006B3r 2  20 rr rr     L7011:	jsr L7033
0006B6r 2  9D rr rr     	sta L7069,x
0006B9r 2  CA           	dex
0006BAr 2  D0 F7        	bne L7011
0006BCr 2  18           	clc		; Convert from BCD and copy out time
0006BDr 2  AD rr rr     	lda TKH1	; Multiply 10s of hours by 10, add to units
0006C0r 2  A2 0A        	ldx #$0a
0006C2r 2  6D rr rr     :	adc TKH2
0006C5r 2  CA           	dex
0006C6r 2  D0 FA        	bne :-
0006C8r 2  AD rr rr     	lda TKH2	; Hours
0006CBr 2  8D rr rr     	sta TimeNow
0006CEr 2  18           	clc
0006CFr 2  AD rr rr     	lda TKM1	; Multiply 10s of minutes by 10, add to units
0006D2r 2  A2 0A        	ldx #$0a
0006D4r 2  6D rr rr     :	adc TKM2
0006D7r 2  CA           	dex
0006D8r 2  D0 FA        	bne :-
0006DAr 2  AD rr rr     	lda TKM2	; Minutes
0006DDr 2  8D rr rr     	sta TimeNow+1
0006E0r 2  18           	clc
0006E1r 2  AD rr rr     	lda TKS1	; Multiply 10s of seconds by 10, add to units
0006E4r 2  A2 0A        	ldx #$0a
0006E6r 2  6D rr rr     :	adc TKS2
0006E9r 2  CA           	dex
0006EAr 2  D0 FA        	bne :-
0006ECr 2  AD rr rr     	lda TKS2	; Seconds
0006EFr 2  8D rr rr     	sta TimeNow+2
0006F2r 2  A9 00        	lda #$00	; Hundredths (not available on Thunderclock)
0006F4r 2  8D rr rr     	sta TimeNow+3
0006F7r 2  60           	rts
