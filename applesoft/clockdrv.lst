000421r 2               ;---------------------------------------------------------
000421r 2               ; BASIC test program for the GS time-getting algorithm
000421r 2               ;---------------------------------------------------------
000421r 2               
000421r 2               ;10 X = 768:Z = 803
000421r 2               ;20 READ Y: IF Y >  - 1 THEN  POKE X,Y:X = X + 1: GOTO 20
000421r 2               ;30 DATA 56,32,31,254,144,1,96,251,194,48,72,72,72,72
000421r 2               ;40 DATA 162,3,13,34,0,0,225,226,48,162,7,104,157,35,3
000421r 2               ;50 DATA 202,16,249,56,251,96,-1
000421r 2               ;60 CALL 768
000421r 2               ;70 WD =  PEEK (Z): REM Weekday (1=Sun...7=Sat)
000421r 2               ;80 MO =  PEEK (Z+2): REM Month (0=Jan...11=Dec)
000421r 2               ;90 DA =  PEEK (Z+3): REM Day (0...30)
000421r 2               ;100 YR =  PEEK (Z+4): REM Year-1900
000421r 2               ;110 HR =  PEEK (Z+5): REM Hour (0...23)
000421r 2               ;120 MN =  PEEK (Z+6): REM Minute (0...59)
000421r 2               ;130 SC =  PEEK (Z+7): REM Second (0...59)
000421r 2               ;140 PRINT "Hour: ";HR;" Minute: ";MN;" Second: ";SC
000421r 2               
000421r 2               GetTimeNSC:
000421r 2  20 rr rr     	jsr NSCEntry
000424r 2  AD rr rr     	lda L0307	; Hours
000427r 2  8D rr rr     	sta TimeNow
00042Ar 2  AD rr rr     	lda L0308	; Minutes
00042Dr 2  8D rr rr     	sta TimeNow+1
000430r 2  AD rr rr     	lda L0309	; Seconds
000433r 2  8D rr rr     	sta TimeNow+2
000436r 2  AD rr rr     	lda L030A	; Hundredths
000439r 2  8D rr rr     	sta TimeNow+3
00043Cr 2  60           	rts
00043Dr 2               
00043Dr 2               CheckForROMX:
00043Dr 2               	; Return with carry clear means we found one
00043Dr 2  2C E0 C0     	bit $C0E0	; Temporarily disable Zip Chip
000440r 2  2C CA FA     	bit $FACA	; Select ROMX Bank 0
000443r 2  2C CA FA     	bit $FACA
000446r 2  2C FE FA     	bit $FAFE
000449r 2  AD FE DF     	lda $DFFE	; Will return $4A if ROMX present
00044Cr 2  C9 4A        	cmp #$4A	;  or $AA if ROMX in Recovery mode
00044Er 2  D0 0B        	bne NoROMX
000450r 2  AD FF DF     	lda $DFFF	; Will return $CD if ROMX present
000453r 2  C9 CD        	cmp #$CD	;  or $55 if ROMX in Recovery mode
000455r 2  D0 04        	bne NoROMX
000457r 2               	; Here we know we have a ROMX
000457r 2  18           	clc
000458r 2  4C rr rr     	jmp DoneROMX
00045Br 2               	NoROMX:
00045Br 2  38           	sec
00045Cr 2               	DoneROMX:
00045Cr 2  2C 51 F8     	bit $F851	; Return to Main Bank (MUST DO, EVEN IF ROMX NOT FOUND!)
00045Fr 2  60           	rts
000460r 2               
000460r 2               GetTimeROMX:
000460r 2  2C E0 C0     	bit $C0E0	; Temporarily disable Zip Chip
000463r 2  2C CA FA     	bit $FACA
000466r 2  2C CA FA     	bit $FACA
000469r 2  2C FE FA     	bit $FAFE	; activate bank 0
00046Cr 2  20 F0 D8     	jsr $D8F0	; read clock through firmware entry point
00046Fr 2  2C 51 F8     	bit $F851	; exit bank 0
000472r 2               
000472r 2  AD B2 02     	lda $2B2	; Hours
000475r 2  8D rr rr     	sta TimeNow
000478r 2  AD B1 02     	lda $2B1	; Minutes
00047Br 2  8D rr rr     	sta TimeNow+1
00047Er 2  AD B0 02     	lda $2B0	; Seconds + $80 ST Oscillator enabled bit
000481r 2  29 7F        	and #$7f	; Seconds
000483r 2  8D rr rr     	sta TimeNow+2
000486r 2  A9 00        	lda #$00	; Hundredths (not available on ROMX)
000488r 2  8D rr rr     	sta TimeNow+3
00048Br 2  60           	rts
00048Cr 2               
00048Cr 2               ;---------------------------------------------------------
00048Cr 2               ; MegaFlash clock support (Apple IIc/IIc+ with MegaFlash)
00048Cr 2               ; https://github.com/ThomasFok/MegaFlash
00048Cr 2               ;
00048Cr 2               ; Design notes: doc/MegaFlash_Clock.md
00048Cr 2               ;
00048Cr 2               ; Activation is handled in MegaFlash ROM; we only check for presence and read time.
00048Cr 2               ; Detection: CMD_GETDEVINFO returns signature $88,$74 in paramreg.
00048Cr 2               ;
00048Cr 2               ; GetTime: CMD_GETPRODOS25TIME returns 6 bytes. Time word (bytes 2-3)
00048Cr 2               ; packs [mday:5][hour:5][min:6]; we extract hour=(time>>6)&$1F,
00048Cr 2               ; min=time&$3F. Byte 1 = seconds.
00048Cr 2               ;---------------------------------------------------------
00048Cr 2               MF_CMDSTATUS	= $C0C0
00048Cr 2               MF_PARAM	= $C0C1
00048Cr 2               MF_CMD_GETDEVINFO	= $10
00048Cr 2               MF_CMD_GETPRODOS25TIME	= $18
00048Cr 2               MF_SIGNATURE1	= $88
00048Cr 2               MF_SIGNATURE2	= $74
00048Cr 2               
00048Cr 2               CheckForMegaFlash:
00048Cr 2               	; ROM activates MegaFlash if present; just check for presence
00048Cr 2               	; Send GETDEVINFO command
00048Cr 2  A9 10        	lda #MF_CMD_GETDEVINFO
00048Er 2  8D C0 C0     	sta MF_CMDSTATUS
000491r 2               	; Wait for busy to clear (with timeout)
000491r 2  A2 64        	ldx #100
000493r 2  2C C0 C0     :	bit MF_CMDSTATUS
000496r 2  10 05        	bpl :+
000498r 2  CA           	dex
000499r 2  D0 F8        	bne :-
00049Br 2               	; Timeout - MegaFlash not present
00049Br 2  38           	sec
00049Cr 2  60           	rts
00049Dr 2               :	; Check for error (bit 6)
00049Dr 2  70 10        	bvs CheckMegaFlashFail
00049Fr 2               	; Verify signature bytes
00049Fr 2  AD C1 C0     	lda MF_PARAM
0004A2r 2  C9 88        	cmp #MF_SIGNATURE1
0004A4r 2  D0 09        	bne CheckMegaFlashFail
0004A6r 2  AD C1 C0     	lda MF_PARAM
0004A9r 2  C9 74        	cmp #MF_SIGNATURE2
0004ABr 2  D0 02        	bne CheckMegaFlashFail
0004ADr 2               	; MegaFlash found
0004ADr 2  18           	clc
0004AEr 2  60           	rts
0004AFr 2               CheckMegaFlashFail:
0004AFr 2  38           	sec
0004B0r 2  60           	rts
0004B1r 2               
0004B1r 2               GetTimeMegaFlash:
0004B1r 2               	; Request ProDOS 2.5 format time (includes seconds)
0004B1r 2  A9 18        	lda #MF_CMD_GETPRODOS25TIME
0004B3r 2  8D C0 C0     	sta MF_CMDSTATUS
0004B6r 2               	; Wait for completion (bounded — slinky or non-MF hardware can leave busy stuck)
0004B6r 2  A2 64        	ldx #100
0004B8r 2  2C C0 C0     :	bit MF_CMDSTATUS
0004BBr 2  10 06        	bpl GetTimeMFReady
0004BDr 2  CA           	dex
0004BEr 2  D0 F8        	bne :-
0004C0r 2  4C rr rr     	jmp GetTimeMFDone	; timeout — do not read param stream
0004C3r 2               GetTimeMFReady:
0004C3r 2  70 47        	bvs GetTimeMFDone	; Error - skip update
0004C5r 2               	; Read 6 bytes: [0]=4ms units, [1]=sec, [2-3]=time word, [4-5]=date
0004C5r 2  AD C1 C0     	lda MF_PARAM		; t4ms - discard
0004C8r 2  AD C1 C0     	lda MF_PARAM		; seconds
0004CBr 2  8D rr rr     	sta MFTime+1
0004CEr 2  AD C1 C0     	lda MF_PARAM		; time lo
0004D1r 2  8D rr rr     	sta MFTime+2
0004D4r 2  AD C1 C0     	lda MF_PARAM		; time hi
0004D7r 2  8D rr rr     	sta MFTime+3
0004DAr 2  AD C1 C0     	lda MF_PARAM		; date lo - discard
0004DDr 2  AD C1 C0     	lda MF_PARAM		; date hi - discard
0004E0r 2               	; Extract: min = time & $3F, hour = (time >> 6) & $1F
0004E0r 2  AD rr rr     	lda MFTime+2
0004E3r 2  29 3F        	and #$3F
0004E5r 2  8D rr rr     	sta TimeNow+1		; Minutes
0004E8r 2  AD rr rr     	lda MFTime+2
0004EBr 2  4A           	lsr a
0004ECr 2  4A           	lsr a
0004EDr 2  4A           	lsr a
0004EEr 2  4A           	lsr a
0004EFr 2  4A           	lsr a
0004F0r 2  4A           	lsr a
0004F1r 2  8D rr rr     	sta MFTime+0		; temp: hour low 2 bits
0004F4r 2  AD rr rr     	lda MFTime+3
0004F7r 2  29 07        	and #$07			; hour bits from high byte
0004F9r 2  0A           	asl a
0004FAr 2  0A           	asl a
0004FBr 2  0D rr rr     	ora MFTime+0
0004FEr 2  8D rr rr     	sta TimeNow		; Hours
000501r 2  AD rr rr     	lda MFTime+1
000504r 2  8D rr rr     	sta TimeNow+2		; Seconds
000507r 2  A9 00        	lda #$00
000509r 2  8D rr rr     	sta TimeNow+3		; Hundredths (MegaFlash has 4ms, we use 0 for simplicity)
00050Cr 2               GetTimeMFDone:
00050Cr 2  60           	rts
00050Dr 2               
00050Dr 2  xx xx xx xx  MFTime:	.res 4		; Temp: [0]=hour bits, [1]=sec, [2]=time_lo, [3]=time_hi
