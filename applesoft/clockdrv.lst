0000D4r 2               InitTime:
0000D4r 2  38           	sec
0000D5r 2  20 1F FE     	jsr $FE1F	; CheckForGS
0000D8r 2  90 44        	bcc FoundClockGS
0000DAr 2  A9 00        	lda #DEBUG_DCLOCK_ONLY
0000DCr 2  F0 03        	beq InitTime_standard
0000DEr 2  4C rr rr     	jmp InitTime_debug_dclock
0000E1r 2               InitTime_standard:
0000E1r 2               	; Apple IIc (VERSION=$06): DClock before anything else on $C0C0 (MegaFlash probe
0000E1r 2               	; after ROMX). Probing MegaFlash first can upset AE RAM / DClock on MF-less IIc.
0000E1r 2  AD B3 FB     	lda VERSION
0000E4r 2  C9 06        	cmp #$06
0000E6r 2  D0 05        	bne InitTime_not_iic
0000E8r 2  20 rr rr     	jsr CheckForDClock
0000EBr 2  90 5D        	bcc FoundClockDClock
0000EDr 2               InitTime_not_iic:
0000EDr 2  AD B3 FB     	lda VERSION
0000F0r 2  C9 06        	cmp #$06
0000F2r 2  F0 05        	beq InitTime_skip_nsc
0000F4r 2  20 rr rr     	jsr CheckForNoSlotClock
0000F7r 2  90 30        	bcc FoundClockNoSlot
0000F9r 2               InitTime_skip_nsc:
0000F9r 2  20 rr rr     	jsr CheckForROMX
0000FCr 2  90 36        	bcc FoundClockROMX
0000FEr 2  20 rr rr     	jsr CheckForMegaFlash
000101r 2  B0 03        	bcs InitTime_megaMiss
000103r 2  4C rr rr     	jmp FoundClockMegaFlash
000106r 2               InitTime_megaMiss:
000106r 2  20 rr rr     	jsr CheckForSlottedClocks
000109r 2  90 02        	bcc InitTime_builtin_ok
00010Br 2               InitTime_no_clock_any:
00010Br 2  38           	sec
00010Cr 2  60           	rts
00010Dr 2               InitTime_builtin_ok:
00010Dr 2  18           	clc
00010Er 2  60           	rts
00010Fr 2               
00010Fr 2               ; IIc only: skip all other clocks; print diagnostics; patch GetTime if DClock OK.
00010Fr 2               InitTime_debug_dclock:
00010Fr 2  AD B3 FB     	lda VERSION
000112r 2  C9 06        	cmp #$06
000114r 2  D0 F5        	bne InitTime_no_clock_any
000116r 2  20 rr rr     	jsr DclockDebugProbe
000119r 2  B0 F0        	bcs InitTime_no_clock_any
00011Br 2  4C rr rr     	jmp FoundClockDClock
00011Er 2               
00011Er 2               FoundClockGS:
00011Er 2               ;---------------------------------------------------------
00011Er 2               ; Patch the entry point of GetTime to the IIgs version
00011Er 2               ;---------------------------------------------------------
00011Er 2  A9 rr        	lda #<GetTimeGS
000120r 2  8D rr rr     	sta GetTime+1
000123r 2  A9 rr        	lda #>GetTimeGS
000125r 2  8D rr rr     	sta GetTime+2
000128r 2  60           	rts
000129r 2               
000129r 2               FoundClockNoSlot:
000129r 2               ;---------------------------------------------------------
000129r 2               ; Patch the entry point of GetTime to the NoSlotClock version
000129r 2               ;---------------------------------------------------------
000129r 2  A9 rr        	lda #<GetTimeNSC
00012Br 2  8D rr rr     	sta GetTime+1
00012Er 2  A9 rr        	lda #>GetTimeNSC
000130r 2  8D rr rr     	sta GetTime+2
000133r 2  60           	rts
000134r 2               
000134r 2               FoundClockROMX:
000134r 2               ;---------------------------------------------------------
000134r 2               ; Patch the entry point of GetTime to the ROMX version
000134r 2               ;---------------------------------------------------------
000134r 2  A9 rr        	lda #<GetTimeROMX
000136r 2  8D rr rr     	sta GetTime+1
000139r 2  A9 rr        	lda #>GetTimeROMX
00013Br 2  8D rr rr     	sta GetTime+2
00013Er 2  60           	rts
00013Fr 2               
00013Fr 2               FoundClockMegaFlash:
00013Fr 2               ;---------------------------------------------------------
00013Fr 2               ; Patch the entry point of GetTime to the MegaFlash version
00013Fr 2               ;---------------------------------------------------------
00013Fr 2  A9 rr        	lda #<GetTimeMegaFlash
000141r 2  8D rr rr     	sta GetTime+1
000144r 2  A9 rr        	lda #>GetTimeMegaFlash
000146r 2  8D rr rr     	sta GetTime+2
000149r 2  60           	rts
00014Ar 2               
00014Ar 2               FoundClockDClock:
00014Ar 2  A9 rr        	lda #<GetTimeDClock
00014Cr 2  8D rr rr     	sta GetTime+1
00014Fr 2  A9 rr        	lda #>GetTimeDClock
000151r 2  8D rr rr     	sta GetTime+2
000154r 2  60           	rts
000155r 2               
000155r 2               ;----------------------------------------------------------------------
000155r 2               ; Applied Engineering DClock (IIc Memory Expansion, DS1215 at slinky $080000 bit0).
000155r 2               ; Protocol from AE DClock disk SOURCE.UTIL (ORCA), 1988 — same unlock pattern as
000155r 2               ; DCLOCK.SYSTEM on doc/D-Clock.dsk: eight bytes C5 3A A3 5C × 2, each bit LSB-first.
000155r 2               ;----------------------------------------------------------------------
000155r 2               DC_ROMSLOT	= $C400
000155r 2               DC_READDR	= $C0C0
000155r 2               DC_REDATA	= $C0C3
000155r 2               DC_C8OFF	= $CFFF
000155r 2               
000155r 2               CheckForDClock:
000155r 2  20 rr rr     	jsr DclockRead
000158r 2  20 rr rr     	jsr DClockValidTime
00015Br 2  60           	rts
00015Cr 2               
00015Cr 2               DclockReset:
00015Cr 2  AD FF CF     	lda DC_C8OFF
00015Fr 2  AD 00 C4     	lda DC_ROMSLOT
000162r 2  A9 00        	lda #$00
000164r 2  8D C0 C0     	sta DC_READDR
000167r 2  8D C1 C0     	sta DC_READDR+1
00016Ar 2  A9 08        	lda #$08
00016Cr 2  8D C2 C0     	sta DC_READDR+2
00016Fr 2  AD C3 C0     	lda DC_REDATA
000172r 2  60           	rts
000173r 2               
000173r 2               DclockEnable:
000173r 2  A0 00        	ldy #$00
000175r 2  B9 rr rr     :	lda DCUnlockPattern,y
000178r 2  20 rr rr     	jsr DclockWrite8
00017Br 2  C8           	iny
00017Cr 2  C0 08        	cpy #$08
00017Er 2  90 F5        	bcc :-
000180r 2  60           	rts
000181r 2               
000181r 2               DCUnlockPattern:
000181r 2  C5 3A A3 5C  	.byte $C5, $3A, $A3, $5C, $C5, $3A, $A3, $5C
000185r 2  C5 3A A3 5C  
000189r 2               
000189r 2               ; Pattern byte in A (SOURCE.UTIL Write8); must not clobber A before first bit write.
000189r 2               DclockWrite8:
000189r 2  8D rr rr     	sta DCW8Byte
00018Cr 2  A0 08        	ldy #$08
00018Er 2  A9 00        	lda #$00
000190r 2  8D C0 C0     	sta DC_READDR
000193r 2  8D C1 C0     	sta DC_READDR+1
000196r 2  A9 08        	lda #$08
000198r 2  8D C2 C0     	sta DC_READDR+2
00019Br 2               DclockWbit:
00019Br 2  AD rr rr     	lda DCW8Byte
00019Er 2  8D C3 C0     	sta DC_REDATA
0001A1r 2  A9 00        	lda #$00
0001A3r 2  8D C0 C0     	sta DC_READDR
0001A6r 2  8D C1 C0     	sta DC_READDR+1
0001A9r 2  4E rr rr     	lsr DCW8Byte
0001ACr 2  88           	dey
0001ADr 2  D0 EC        	bne DclockWbit
0001AFr 2  60           	rts
0001B0r 2               
0001B0r 2               DclockRead8:
0001B0r 2  A0 08        	ldy #$08
0001B2r 2  A9 00        	lda #$00
0001B4r 2  8D C0 C0     	sta DC_READDR
0001B7r 2  8D C1 C0     	sta DC_READDR+1
0001BAr 2  A9 08        	lda #$08
0001BCr 2  8D C2 C0     	sta DC_READDR+2
0001BFr 2  A9 00        	lda #$00		; running byte (AE Read8 assumes A defined at first pha)
0001C1r 2               DclockRbit:
0001C1r 2  48           	pha
0001C2r 2  AD C3 C0     	lda DC_REDATA
0001C5r 2  4A           	lsr a
0001C6r 2  68           	pla
0001C7r 2  6A           	ror a
0001C8r 2  88           	dey
0001C9r 2  D0 F6        	bne DclockRbit
0001CBr 2  60           	rts
0001CCr 2               
0001CCr 2               DclockRestore:
0001CCr 2  A9 08        	lda #$08
0001CEr 2  8D C2 C0     	sta DC_READDR+2
0001D1r 2  A9 00        	lda #$00
0001D3r 2  8D C0 C0     	sta DC_READDR
0001D6r 2  8D C1 C0     	sta DC_READDR+1
0001D9r 2  AD rr rr     	lda DCPreserve
0001DCr 2  8D C3 C0     	sta DC_REDATA
0001DFr 2  AD FF CF     	lda DC_C8OFF
0001E2r 2  60           	rts
0001E3r 2               
0001E3r 2               ; DEBUG: two reads + validation + decoded TimeNow to screen (monitor PRBYTE/COUT1).
0001E3r 2               DclockDebugProbe:
0001E3r 2  20 8E FD     	jsr CROUT
