000751r 1               
000751r 1               ; A2Speed wrapper for SPF MegaFlash time read:
000751r 1               ; SPF returns a first byte in 4 ms units and currently zeros TimeNow+3.
000751r 1               ; Convert that 0..249 range to exact hundredths via a lookup table.
000751r 1               GetTimeMegaFlashA2:
000751r 1  A9 18                lda     #MF_CMD_GETPRODOS25TIME
000753r 1  8D C0 C0             sta     MF_CMDSTATUS
000756r 1               @mf_wait:
000756r 1  2C C0 C0             bit     MF_CMDSTATUS
000759r 1  30 FB                bmi     @mf_wait
00075Br 1  70 4E                bvs     @mf_done
00075Dr 1  AD C1 C0             lda     MF_PARAM                ; t4ms (0..249 in 4 ms units)
000760r 1  8D rr rr             sta     MFTimeA2+0
000763r 1  AD C1 C0             lda     MF_PARAM                ; seconds
000766r 1  8D rr rr             sta     MFTimeA2+1
000769r 1  AD C1 C0             lda     MF_PARAM                ; time lo
00076Cr 1  8D rr rr             sta     MFTimeA2+2
00076Fr 1  AD C1 C0             lda     MF_PARAM                ; time hi
000772r 1  8D rr rr             sta     MFTimeA2+3
000775r 1  AD C1 C0             lda     MF_PARAM                ; date lo - discard
000778r 1  AD C1 C0             lda     MF_PARAM                ; date hi - discard
00077Br 1  AE rr rr             ldx     MFTimeA2+0
00077Er 1  BD rr rr             lda     MegaFlashHundredths,x
000781r 1  8D rr rr             sta     TimeNow+3               ; Hundredths
000784r 1  AD rr rr             lda     MFTimeA2+2
000787r 1  29 3F                and     #$3F
000789r 1  8D rr rr             sta     TimeNow+1               ; Minutes
00078Cr 1  AD rr rr             lda     MFTimeA2+2
00078Fr 1  4A                   lsr     a
000790r 1  4A                   lsr     a
000791r 1  4A                   lsr     a
000792r 1  4A                   lsr     a
000793r 1  4A                   lsr     a
000794r 1  4A                   lsr     a
000795r 1  8D rr rr             sta     MFTimeA2+0              ; temp: hour low 2 bits
000798r 1  AD rr rr             lda     MFTimeA2+3
00079Br 1  29 07                and     #$07
00079Dr 1  0A                   asl     a
00079Er 1  0A                   asl     a
00079Fr 1  0D rr rr             ora     MFTimeA2+0
0007A2r 1  8D rr rr             sta     TimeNow                 ; Hours
0007A5r 1  AD rr rr             lda     MFTimeA2+1
0007A8r 1  8D rr rr             sta     TimeNow+2               ; Seconds
0007ABr 1               @mf_done:
0007ABr 1  60                   rts
0007ACr 1               
0007ACr 1               MFTimeA2:
0007ACr 1  xx xx xx xx          .res    4
0007B0r 1               
0007B0r 1               MegaFlashHundredths:
0007B0r 1  00 00 00 01          .repeat 250, I
0007B4r 1  01 02 02 02  
0007B8r 1  03 03 04 04  
0008AAr 1                       .byte   (I * 4) / 10
0008AAr 1                       .endrepeat
