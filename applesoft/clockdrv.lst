000000r 1               ; A2SPEED clock driver for Applesoft (ProDOS/BASIC.SYSTEM)
000000r 1               ; Safer wrapper around SPF gettime routines.
000000r 1               ;
000000r 1               ; Entry points (load at $7000; see clockdrv.lst/map):
000000r 1               ;   $7000 CLOCK_INIT  - detect/select backend (no self-modifying GetTime vector)
000000r 1               ;   $704E CLOCK_READ  - sample selected backend into TimeNow (see clockdrv.lst; sync A2SPEED.bas)
000000r 1               ;
000000r 1               ; Detection priority (first match wins):
000000r 1               ;   1 IIgs   2 ROMX   3 MegaFlash   4 No-Slot Clock
000000r 1               ;   5 TimeMaster II H.O. (slot ROM id $4D/$D9 at Cn00-01; AE ROM Rev 5)
000000r 1               ; Thunderclock is not selected: 1 s resolution is too coarse for A2Speed wall timing.
000000r 1               ; TimeMaster read still uses SPF GetTimeThunderclock (BCD slot path; name is historical).
000000r 1               
000000r 1                       UTILPTR = $07
000000r 1               
000000r 1                       KIND_NONE   = 0
000000r 1                       KIND_GS     = 1
000000r 1                       KIND_ROMX   = 2
000000r 1                       KIND_MEGA   = 3
000000r 1                       KIND_NSC    = 4
000000r 1                       KIND_TM     = 5
000000r 1               
000000r 1                       .segment "CODE"
000000r 1                       .export CLOCK_KIND, TimeNow, ClockSlot
000000r 1               
000000r 1               CLOCK_INIT:
000000r 1  20 rr rr             jsr     SaveZP
000003r 1  A9 00                lda     #KIND_NONE
000005r 1  8D rr rr             sta     CLOCK_KIND
000008r 1               
000008r 1                       ; IIgs
000008r 1  38                   sec
000009r 1  20 1F FE             jsr     $FE1F
00000Cr 1  B0 08                bcs     @chk_romx
00000Er 1  A9 01                lda     #KIND_GS
000010r 1  8D rr rr             sta     CLOCK_KIND
000013r 1  4C rr rr             jmp     @done_init
000016r 1               
000016r 1               @chk_romx:
000016r 1  20 rr rr             jsr     CheckForROMX
000019r 1  B0 08                bcs     @chk_mega
00001Br 1  A9 02                lda     #KIND_ROMX
00001Dr 1  8D rr rr             sta     CLOCK_KIND
000020r 1  4C rr rr             jmp     @done_init
000023r 1               
000023r 1               @chk_mega:
000023r 1  20 rr rr             jsr     CheckForMegaFlash
000026r 1  B0 08                bcs     @chk_nsc
000028r 1  A9 03                lda     #KIND_MEGA
00002Ar 1  8D rr rr             sta     CLOCK_KIND
00002Dr 1  4C rr rr             jmp     @done_init
000030r 1               
000030r 1               @chk_nsc:
000030r 1  20 rr rr             jsr     CheckForNoSlotClock
000033r 1  B0 08                bcs     @chk_tm
000035r 1  A9 04                lda     #KIND_NSC
000037r 1  8D rr rr             sta     CLOCK_KIND
00003Ar 1  4C rr rr             jmp     @done_init
00003Dr 1               
00003Dr 1               @chk_tm:
00003Dr 1  20 rr rr             jsr     CheckForTimeMaster
000040r 1  B0 08                bcs     @done_init
000042r 1  A9 05                lda     #KIND_TM
000044r 1  8D rr rr             sta     CLOCK_KIND
000047r 1  4C rr rr             jmp     @done_init
00004Ar 1               
00004Ar 1               @done_init:
00004Ar 1  20 rr rr             jsr     RestoreZP
00004Dr 1  60                   rts
00004Er 1               
00004Er 1               CLOCK_READ:
00004Er 1  20 rr rr             jsr     SaveZP
000051r 1  AD rr rr             lda     CLOCK_KIND
000054r 1  C9 01                cmp     #KIND_GS
000056r 1  D0 06                bne     @r2
000058r 1  20 rr rr             jsr     GetTimeGS
00005Br 1  4C rr rr             jmp     @done_read
00005Er 1               @r2:
00005Er 1  C9 02                cmp     #KIND_ROMX
000060r 1  D0 06                bne     @r3
000062r 1  20 rr rr             jsr     GetTimeROMX
000065r 1  4C rr rr             jmp     @done_read
000068r 1               @r3:
000068r 1  C9 03                cmp     #KIND_MEGA
00006Ar 1  D0 06                bne     @r4
00006Cr 1  20 rr rr             jsr     GetTimeMegaFlashA2
00006Fr 1  4C rr rr             jmp     @done_read
000072r 1               @r4:
000072r 1  C9 04                cmp     #KIND_NSC
000074r 1  D0 06                bne     @r5
000076r 1  20 rr rr             jsr     GetTimeNSC
000079r 1  4C rr rr             jmp     @done_read
00007Cr 1               @r5:
00007Cr 1  C9 05                cmp     #KIND_TM
00007Er 1  D0 06                bne     @done_read
000080r 1  20 rr rr             jsr     GetTimeTimeMaster
000083r 1  4C rr rr             jmp     @done_read
000086r 1               
000086r 1               @done_read:
000086r 1  20 rr rr             jsr     RestoreZP
000089r 1  60                   rts
00008Ar 1               
00008Ar 1               GetTimeTimeMaster:
00008Ar 1  4C rr rr             jmp     GetTimeThunderclock
00008Dr 1               
00008Dr 1               SaveZP:
00008Dr 1  A2 00                ldx     #$00
00008Fr 1               @sloop:
00008Fr 1  B5 00                lda     $00,x
000091r 1  9D rr rr             sta     ZPSAVE,x
000094r 1  E8                   inx
000095r 1  D0 F8                bne     @sloop
000097r 1  60                   rts
000098r 1               
000098r 1               RestoreZP:
000098r 1  A2 00                ldx     #$00
00009Ar 1               @rloop:
00009Ar 1  BD rr rr             lda     ZPSAVE,x
00009Dr 1  95 00                sta     $00,x
00009Fr 1  E8                   inx
0000A0r 1  D0 F8                bne     @rloop
0000A2r 1  60                   rts
0000A3r 1               
0000A3r 1               ; Applied Engineering TimeMaster II H.O. — ROM id at Cn00-01 ($4D $D9), not Thunder $08 $78 $28.
0000A3r 1               CheckForTimeMaster:
0000A3r 1  38                   sec
0000A4r 1  A2 07                ldx     #$07
0000A6r 1               @tmloop:
0000A6r 1  18                   clc
0000A7r 1  8A                   txa
0000A8r 1  69 C0                adc     #$c0
0000AAr 1  85 08                sta     UTILPTR+1
0000ACr 1  A9 00                lda     #$00
0000AEr 1  85 07                sta     UTILPTR
0000B0r 1  A0 00                ldy     #$00
0000B2r 1  B1 07                lda     (UTILPTR),y
0000B4r 1  C9 4D                cmp     #$4D
0000B6r 1  D0 0C                bne     @tmnext
0000B8r 1  C8                   iny
0000B9r 1  B1 07                lda     (UTILPTR),y
0000BBr 1  C9 D9                cmp     #$D9
0000BDr 1  D0 05                bne     @tmnext
0000BFr 1  8E rr rr             stx     ClockSlot
0000C2r 1  18                   clc
0000C3r 1  60                   rts
0000C4r 1               @tmnext:
0000C4r 1  CA                   dex
0000C5r 1  D0 DF                bne     @tmloop
0000C7r 1  38                   sec
0000C8r 1  60                   rts
