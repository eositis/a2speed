00037Cr 2               CheckForSlottedClocks:
00037Cr 2               ;---------------------------------------------------------
00037Cr 2               ; Look for clocks via signature in firmware
00037Cr 2               ;---------------------------------------------------------
00037Cr 2  38           	sec
00037Dr 2               FindClockSlot:
00037Dr 2  A9 00        	lda #$00
00037Fr 2  A8           	tay
000380r 2  85 07        	sta UTILPTR
000382r 2  8D rr rr     	sta ClockSlot
000385r 2  A2 07        	ldx #$07 ; Slot number
000387r 2               FindClockSlotLoop:
000387r 2  18           	clc
000388r 2  8A           	txa
000389r 2  69 C0        	adc #$c0
00038Br 2  85 08        	sta UTILPTR+1
00038Dr 2  A0 00        	ldy #$00		; Lookup offset
00038Fr 2  B1 07        	lda (UTILPTR),y
000391r 2  C9 08        	cmp #$08		; Is $Cn00 == $08?
000393r 2  D0 17        	bne NotThunder
000395r 2  C8           	iny			; Lookup offset
000396r 2  B1 07        	lda (UTILPTR),y
000398r 2  C9 78        	cmp #$78		; Is $Cn01 == $78?
00039Ar 2  D0 10        	bne NotThunder
00039Cr 2  C8           	iny			; Lookup offset
00039Dr 2  B1 07        	lda (UTILPTR),y
00039Fr 2  C9 28        	cmp #$28		; Is $Cn02 == $28?
0003A1r 2  D0 09        	bne NotThunder
0003A3r 2               ; Ok, we have a set of signature bytes for a Thunderclock.
0003A3r 2  8E rr rr     	stx ClockSlot
0003A6r 2  20 rr rr     	jsr PrepThunderclock
0003A9r 2  4C rr rr     	jmp FindClockSlotDone
0003ACr 2               NotThunder:
0003ACr 2               	; Check for other slotted clocks
0003ACr 2               FindClockSlotNext:
0003ACr 2  CA           	dex
0003ADr 2  D0 D8        	bne FindClockSlotLoop
0003AFr 2               ; All done now, return with carry clear if we found a clock
0003AFr 2               FindClockSlotDone:
0003AFr 2  38           	sec
0003B0r 2  AD rr rr     	lda ClockSlot
0003B3r 2  F0 01        	beq :+
0003B5r 2  18           	clc
0003B6r 2  60           :	rts
0003B7r 2  00           ClockSlot:	.byte 0
