000281r 2  A9 A0        	lda #$a0
000283r 2  20 ED FD     	jsr COUT1
000286r 2  C8           	iny
000287r 2  C0 08        	cpy #$08
000289r 2  90 F0        	bcc @p8
00028Br 2  4C 8E FD     	jmp CROUT
00028Er 2               
00028Er 2               DCdbgFillTimeNow:
00028Er 2  AD rr rr     	lda DCBuf+0
000291r 2  20 rr rr     	jsr DC_BCD2Binary
