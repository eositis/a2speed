0000C9r 2               InitTime:
0000C9r 2  38           	sec
0000CAr 2  20 1F FE     	jsr $FE1F	; CheckForGS
0000CDr 2  90 13        	bcc FoundClockGS
0000CFr 2  20 rr rr     	jsr CheckForNoSlotClock
0000D2r 2  90 19        	bcc FoundClockNoSlot
0000D4r 2  20 rr rr     	jsr CheckForROMX
0000D7r 2  90 1F        	bcc FoundClockROMX
0000D9r 2  20 rr rr     	jsr CheckForMegaFlash
0000DCr 2  90 25        	bcc FoundClockMegaFlash
0000DEr 2  20 rr rr     	jsr CheckForSlottedClocks
0000E1r 2  60           	rts
0000E2r 2               
0000E2r 2               FoundClockGS:
0000E2r 2               ;---------------------------------------------------------
0000E2r 2               ; Patch the entry point of GetTime to the IIgs version
0000E2r 2               ;---------------------------------------------------------
0000E2r 2  A9 rr        	lda #<GetTimeGS
0000E4r 2  8D rr rr     	sta GetTime+1
0000E7r 2  A9 rr        	lda #>GetTimeGS
0000E9r 2  8D rr rr     	sta GetTime+2
0000ECr 2  60           	rts
0000EDr 2               
0000EDr 2               FoundClockNoSlot:
0000EDr 2               ;---------------------------------------------------------
0000EDr 2               ; Patch the entry point of GetTime to the NoSlotClock version
0000EDr 2               ;---------------------------------------------------------
0000EDr 2  A9 rr        	lda #<GetTimeNSC
0000EFr 2  8D rr rr     	sta GetTime+1
0000F2r 2  A9 rr        	lda #>GetTimeNSC
0000F4r 2  8D rr rr     	sta GetTime+2
0000F7r 2  60           	rts
0000F8r 2               
0000F8r 2               FoundClockROMX:
0000F8r 2               ;---------------------------------------------------------
0000F8r 2               ; Patch the entry point of GetTime to the ROMX version
0000F8r 2               ;---------------------------------------------------------
0000F8r 2  A9 rr        	lda #<GetTimeROMX
0000FAr 2  8D rr rr     	sta GetTime+1
0000FDr 2  A9 rr        	lda #>GetTimeROMX
0000FFr 2  8D rr rr     	sta GetTime+2
000102r 2  60           	rts
000103r 2               
000103r 2               FoundClockMegaFlash:
000103r 2               ;---------------------------------------------------------
000103r 2               ; Patch the entry point of GetTime to the MegaFlash version
000103r 2               ;---------------------------------------------------------
000103r 2  A9 rr        	lda #<GetTimeMegaFlash
000105r 2  8D rr rr     	sta GetTime+1
000108r 2  A9 rr        	lda #>GetTimeMegaFlash
00010Ar 2  8D rr rr     	sta GetTime+2
00010Dr 2  60           	rts
00010Er 2               
00010Er 2               GetTime:
00010Er 2  20 00 00     	jsr $0000
000111r 2  60           	rts
000112r 2               
000112r 2               
000112r 2               GetTimeGS:
000112r 2               ;---------------------------------------------------------
000112r 2               ; Get the current time on the GS
000112r 2               ;---------------------------------------------------------
000112r 2               .P816
000112r 2  18           	clc
000113r 2  FB           	.byte $FB	; xce
000114r 2  C2 30        	rep #$30
000116r 2               .A16
000116r 2               .I16
000116r 2  48           	pha
000117r 2  48           	pha
000118r 2  48           	pha
000119r 2  48           	pha
00011Ar 2  A2 03 0D     	ldx #$0D03
00011Dr 2  22 00 00 E1  	jsl $E10000
000121r 2  E2 30        	sep #$30
000123r 2               .I8
000123r 2  A2 07        	ldx #7
000125r 2               GTGSLoop:
000125r 2  68           	pla
000126r 2  9D rr rr     	sta GSTime,X
000129r 2  CA           	dex
00012Ar 2  10 F9        	bpl GTGSLoop
00012Cr 2  38           	sec
00012Dr 2  FB           	.byte $FB	; xce
00012Er 2               .A8
00012Er 2  AD rr rr     	lda GSTime+5	; Hours
000131r 2  8D rr rr     	sta TimeNow
000134r 2  AD rr rr     	lda GSTime+6	; Minutes
000137r 2  8D rr rr     	sta TimeNow+1
00013Ar 2  AD rr rr     	lda GSTime+7	; Seconds
00013Dr 2  8D rr rr     	sta TimeNow+2
000140r 2  A9 00        	lda #$00	; Hundredths (not available on GS)
000142r 2  8D rr rr     	sta TimeNow+3
000145r 2  60           	rts
000146r 2               .P02
000146r 2               
000146r 2               GSTime:
000146r 2  xx xx xx xx  	.res 8
00014Ar 2  xx xx xx xx  
00014Er 2               
00014Er 2               ;---------------------------------------------------------
00014Er 2               ; BASIC test program for the GS time-getting algorithm
00014Er 2               ;---------------------------------------------------------
00014Er 2               
00014Er 2               ;10 X = 768:Z = 803
00014Er 2               ;20 READ Y: IF Y >  - 1 THEN  POKE X,Y:X = X + 1: GOTO 20
00014Er 2               ;30 DATA 56,32,31,254,144,1,96,251,194,48,72,72,72,72
00014Er 2               ;40 DATA 162,3,13,34,0,0,225,226,48,162,7,104,157,35,3
00014Er 2               ;50 DATA 202,16,249,56,251,96,-1
00014Er 2               ;60 CALL 768
00014Er 2               ;70 WD =  PEEK (Z): REM Weekday (1=Sun...7=Sat)
00014Er 2               ;80 MO =  PEEK (Z+2): REM Month (0=Jan...11=Dec)
00014Er 2               ;90 DA =  PEEK (Z+3): REM Day (0...30)
00014Er 2               ;100 YR =  PEEK (Z+4): REM Year-1900
00014Er 2               ;110 HR =  PEEK (Z+5): REM Hour (0...23)
00014Er 2               ;120 MN =  PEEK (Z+6): REM Minute (0...59)
00014Er 2               ;130 SC =  PEEK (Z+7): REM Second (0...59)
00014Er 2               ;140 PRINT "Hour: ";HR;" Minute: ";MN;" Second: ";SC
00014Er 2               
00014Er 2               GetTimeNSC:
00014Er 2  20 rr rr     	jsr NSCEntry
000151r 2  AD rr rr     	lda L0307	; Hours
000154r 2  8D rr rr     	sta TimeNow
000157r 2  AD rr rr     	lda L0308	; Minutes
00015Ar 2  8D rr rr     	sta TimeNow+1
00015Dr 2  AD rr rr     	lda L0309	; Seconds
000160r 2  8D rr rr     	sta TimeNow+2
000163r 2  AD rr rr     	lda L030A	; Hundredths
000166r 2  8D rr rr     	sta TimeNow+3
000169r 2  60           	rts
00016Ar 2               
00016Ar 2               CheckForROMX:
00016Ar 2               	; Return with carry clear means we found one
00016Ar 2  2C E0 C0     	bit $C0E0	; Temporarily disable Zip Chip
00016Dr 2  2C CA FA     	bit $FACA	; Select ROMX Bank 0
000170r 2  2C CA FA     	bit $FACA
000173r 2  2C FE FA     	bit $FAFE
000176r 2  AD FE DF     	lda $DFFE	; Will return $4A if ROMX present
000179r 2  C9 4A        	cmp #$4A	;  or $AA if ROMX in Recovery mode
00017Br 2  D0 0B        	bne NoROMX
00017Dr 2  AD FF DF     	lda $DFFF	; Will return $CD if ROMX present
000180r 2  C9 CD        	cmp #$CD	;  or $55 if ROMX in Recovery mode
000182r 2  D0 04        	bne NoROMX
000184r 2               	; Here we know we have a ROMX
000184r 2  18           	clc
000185r 2  4C rr rr     	jmp DoneROMX
000188r 2               	NoROMX:
000188r 2  38           	sec
000189r 2               	DoneROMX:
000189r 2  2C 51 F8     	bit $F851	; Return to Main Bank (MUST DO, EVEN IF ROMX NOT FOUND!)
00018Cr 2  60           	rts
00018Dr 2               
00018Dr 2               GetTimeROMX:
00018Dr 2  2C E0 C0     	bit $C0E0	; Temporarily disable Zip Chip
000190r 2  2C CA FA     	bit $FACA
000193r 2  2C CA FA     	bit $FACA
000196r 2  2C FE FA     	bit $FAFE	; activate bank 0
000199r 2  20 F0 D8     	jsr $D8F0	; read clock through firmware entry point
00019Cr 2  2C 51 F8     	bit $F851	; exit bank 0
00019Fr 2               
00019Fr 2  AD B2 02     	lda $2B2	; Hours
0001A2r 2  8D rr rr     	sta TimeNow
0001A5r 2  AD B1 02     	lda $2B1	; Minutes
0001A8r 2  8D rr rr     	sta TimeNow+1
0001ABr 2  AD B0 02     	lda $2B0	; Seconds + $80 ST Oscillator enabled bit
0001AEr 2  29 7F        	and #$7f	; Seconds
0001B0r 2  8D rr rr     	sta TimeNow+2
0001B3r 2  A9 00        	lda #$00	; Hundredths (not available on ROMX)
0001B5r 2  8D rr rr     	sta TimeNow+3
0001B8r 2  60           	rts
0001B9r 2               
0001B9r 2               ;---------------------------------------------------------
0001B9r 2               ; MegaFlash clock support (Apple IIc/IIc+ with MegaFlash)
0001B9r 2               ; https://github.com/ThomasFok/MegaFlash
0001B9r 2               ;
0001B9r 2               ; Design notes: doc/MegaFlash_Clock.md
0001B9r 2               ;
0001B9r 2               ; Activation is handled in MegaFlash ROM; we only check presence and read time.
0001B9r 2               ; Detection: CMD_GETDEVINFO returns signature $88,$74 in paramreg.
0001B9r 2               ;
0001B9r 2               ; GetTime: CMD_GETPRODOS25TIME returns 6 bytes. Time word (bytes 2-3)
0001B9r 2               ; packs [mday:5][hour:5][min:6]; we extract hour=(time>>6)&$1F,
0001B9r 2               ; min=time&$3F. Byte 1 = seconds.
0001B9r 2               ;---------------------------------------------------------
0001B9r 2               MF_CMDSTATUS	= $C0C0
0001B9r 2               MF_PARAM	= $C0C1
0001B9r 2               MF_CMD_GETDEVINFO	= $10
0001B9r 2               MF_CMD_GETPRODOS25TIME	= $18
0001B9r 2               MF_SIGNATURE1	= $88
0001B9r 2               MF_SIGNATURE2	= $74
0001B9r 2               
0001B9r 2               CheckForMegaFlash:
0001B9r 2               	; ROM activates MegaFlash if present; just check for presence
0001B9r 2               	; Send GETDEVINFO command
0001B9r 2  A9 10        	lda #MF_CMD_GETDEVINFO
0001BBr 2  8D C0 C0     	sta MF_CMDSTATUS
0001BEr 2               	; Wait for busy to clear (with timeout)
0001BEr 2  A2 64        	ldx #100
0001C0r 2  2C C0 C0     :	bit MF_CMDSTATUS
0001C3r 2  10 05        	bpl :+
0001C5r 2  CA           	dex
0001C6r 2  D0 F8        	bne :-
0001C8r 2               	; Timeout - MegaFlash not present
0001C8r 2  38           	sec
0001C9r 2  60           	rts
0001CAr 2               :	; Check for error (bit 6)
0001CAr 2  70 10        	bvs CheckMegaFlashFail
0001CCr 2               	; Verify signature bytes
0001CCr 2  AD C1 C0     	lda MF_PARAM
0001CFr 2  C9 88        	cmp #MF_SIGNATURE1
0001D1r 2  D0 09        	bne CheckMegaFlashFail
0001D3r 2  AD C1 C0     	lda MF_PARAM
0001D6r 2  C9 74        	cmp #MF_SIGNATURE2
0001D8r 2  D0 02        	bne CheckMegaFlashFail
0001DAr 2               	; MegaFlash found
0001DAr 2  18           	clc
0001DBr 2  60           	rts
0001DCr 2               CheckMegaFlashFail:
0001DCr 2  38           	sec
0001DDr 2  60           	rts
0001DEr 2               
0001DEr 2               GetTimeMegaFlash:
0001DEr 2               	; Request ProDOS 2.5 format time (includes seconds)
0001DEr 2  A9 18        	lda #MF_CMD_GETPRODOS25TIME
0001E0r 2  8D C0 C0     	sta MF_CMDSTATUS
0001E3r 2               	; Wait for completion
0001E3r 2  2C C0 C0     :	bit MF_CMDSTATUS
0001E6r 2  30 FB        	bmi :-
0001E8r 2  70 47        	bvs GetTimeMFDone	; Error - skip update
0001EAr 2               	; Read 6 bytes: [0]=4ms units, [1]=sec, [2-3]=time word, [4-5]=date
0001EAr 2  AD C1 C0     	lda MF_PARAM		; t4ms - discard
0001EDr 2  AD C1 C0     	lda MF_PARAM		; seconds
0001F0r 2  8D rr rr     	sta MFTime+1
0001F3r 2  AD C1 C0     	lda MF_PARAM		; time lo
0001F6r 2  8D rr rr     	sta MFTime+2
0001F9r 2  AD C1 C0     	lda MF_PARAM		; time hi
0001FCr 2  8D rr rr     	sta MFTime+3
0001FFr 2  AD C1 C0     	lda MF_PARAM		; date lo - discard
000202r 2  AD C1 C0     	lda MF_PARAM		; date hi - discard
000205r 2               	; Extract: min = time & $3F, hour = (time >> 6) & $1F
000205r 2  AD rr rr     	lda MFTime+2
000208r 2  29 3F        	and #$3F
00020Ar 2  8D rr rr     	sta TimeNow+1		; Minutes
00020Dr 2  AD rr rr     	lda MFTime+2
000210r 2  4A           	lsr a
000211r 2  4A           	lsr a
000212r 2  4A           	lsr a
000213r 2  4A           	lsr a
000214r 2  4A           	lsr a
000215r 2  4A           	lsr a
000216r 2  8D rr rr     	sta MFTime+0		; temp: hour low 2 bits
000219r 2  AD rr rr     	lda MFTime+3
00021Cr 2  29 07        	and #$07			; hour bits from high byte
00021Er 2  0A           	asl a
00021Fr 2  0A           	asl a
000220r 2  0D rr rr     	ora MFTime+0
000223r 2  8D rr rr     	sta TimeNow		; Hours
000226r 2  AD rr rr     	lda MFTime+1
000229r 2  8D rr rr     	sta TimeNow+2		; Seconds
00022Cr 2  A9 00        	lda #$00
00022Er 2  8D rr rr     	sta TimeNow+3		; Hundredths (MegaFlash has 4ms, we use 0 for simplicity)
000231r 2               GetTimeMFDone:
000231r 2  60           	rts
000232r 2               
000232r 2  xx xx xx xx  MFTime:	.res 4		; Temp: [0]=hour bits, [1]=sec, [2]=time_lo, [3]=time_hi
000236r 2               
000236r 2               CheckForNoSlotClock:
000236r 2  20 rr rr     	jsr PrepNoSlotClock	; Prepare the driver
000239r 2  20 rr rr     	jsr NSCEntry		; Call it to get the time
00023Cr 2  AD rr rr     	lda L0304		; Signature will be non-zero if NSC exists
00023Fr 2  18           	clc
000240r 2  D0 01        	bne :+
000242r 2  38           	sec
000243r 2  60           :	rts
000244r 2               
000244r 2               PrepNoSlotClock:
000244r 2               ;---------------------------------------------------------
000244r 2               ; Look for a NoSlotClock
000244r 2               ;---------------------------------------------------------
000244r 2               
000244r 2               L3A3A	= $3A3A
000244r 2               LDA9A	= $DA9A
000244r 2               LDD6C	= $DD6C
000244r 2               LDEBE	= $DEBE
000244r 2               LDFE3	= $DFE3
000244r 2               LE3E9	= $E3E9
000244r 2               
000244r 2  A9 00        L0260:	lda #$00
000246r 2  8D rr rr     	sta L02DE
000249r 2  A9 03        	lda #$03
00024Br 2  09 C0        L0267:  ora #$C0
00024Dr 2  8D rr rr     	sta L031F
000250r 2  8D rr rr     L026C:  sta L0322
000253r 2  8D rr rr     	sta L0331
000256r 2  8D rr rr     	sta L033F
000259r 2  A9 03        	lda #$03
00025Br 2  8D rr rr     	sta L02DF
00025Er 2  D0 16        	bne L0292
000260r 2  00           	brk
000261r 2  00           	brk
