000005r 1  00           param_nhi: .byte 0
000006r 1  00           param_mlo: .byte 0
000007r 1  00           param_mhi: .byte 0
000008r 1               
000008r 1               bench_main:
000008r 1  D8                   cld                             ; BASIC may leave D set; keep binary math
000009r 1  AD rr rr             lda     param_op
00000Cr 1  C9 01                cmp     #1
