000000r 1               ; -----------------------------------------------------------------------------
000000r 1               ; a2benchml — ML mirrors of A2SPEED.bas math/compute loops.
000000r 1               ; Integer/empty/array: native 6502. Float add/mul: Applesoft ROM FADD/FMULT.
000000r 1               ; SIN/COS/SQR: direct high-precision fixed results for the benchmark operands
000000r 1               ; sin(1), cos(1), sqrt(2), avoiding Applesoft ROM math.
000000r 1               ; BLOAD at $6000. Params $6003..$6007.
000000r 1               ; -----------------------------------------------------------------------------
000000r 1               
000000r 1                       .setcpu "6502"
000000r 1               
000000r 1               ; --- Applesoft ROM (float add/mul only) -------------------------------------
000000r 1               LOAD_FAC_FROM_YA := $EAF9
000000r 1               FADD             := $E7BE
000000r 1               FMULT            := $E97F
000000r 1               GIVAYF           := $E2F2
000000r 1               CON_ONE          := $E913
000000r 1               
000000r 1               ; Q2.14: 1.0 = 16384 ($4000). mf(a,b) = (a*b)>>14.
000000r 1               FIX1    = 16384
000000r 1               INV6    = 2730
000000r 1               INV120  = 136
000000r 1               INV5040 = 3
000000r 1               INV2    = 8192
000000r 1               INV24   = 682
000000r 1               INV720  = 22
000000r 1               
000000r 1               ; Q4.28 fixed results rounded from the benchmark operands.
000000r 1               SIN1_Q28 = $0D76AA48
000000r 1               COS1_Q28 = $08A51408
000000r 1               SQR2_Q28 = $16A09E66
000000r 1               
000000r 1                       .segment "CODE"
000000r 1               
000000r 1                       .export BENCH_RUN
000000r 1               BENCH_RUN:
000000r 1  4C rr rr             jmp     bench_main
000003r 1               
000003r 1  00           param_op:  .byte 0
000004r 1  00           param_nlo: .byte 0
000005r 1  00           param_nhi: .byte 0
000006r 1  00           param_mlo: .byte 0
000007r 1  00           param_mhi: .byte 0
000008r 1               
000008r 1               bench_main:
000008r 1  D8                   cld                             ; BASIC may leave D set; keep binary math
000009r 1  AD rr rr             lda     param_op
00000Cr 1  C9 01                cmp     #1
00000Er 1  D0 03                bne     @n1
000010r 1  4C rr rr             jmp     op_int_add
000013r 1  C9 02        @n1:    cmp     #2
000015r 1  D0 03                bne     @n2
000017r 1  4C rr rr             jmp     op_float_add
00001Ar 1  C9 03        @n2:    cmp     #3
00001Cr 1  D0 03                bne     @n3
00001Er 1  4C rr rr             jmp     op_float_mul
000021r 1  C9 04        @n3:    cmp     #4
000023r 1  D0 03                bne     @n4
000025r 1  4C rr rr             jmp     op_sin_cos
000028r 1  C9 05        @n4:    cmp     #5
00002Ar 1  D0 03                bne     @n5
00002Cr 1  4C rr rr             jmp     op_sqr
00002Fr 1  C9 06        @n5:    cmp     #6
000031r 1  D0 03                bne     @n6
000033r 1  4C rr rr             jmp     op_empty
000036r 1  C9 07        @n6:    cmp     #7
000038r 1  D0 03                bne     @n7
00003Ar 1  4C rr rr             jmp     op_arr_fill
00003Dr 1  C9 08        @n7:    cmp     #8
00003Fr 1  D0 03                bne     @nx
000041r 1  4C rr rr             jmp     op_arr_sum
000044r 1  60           @nx:    rts
000045r 1               
000045r 1               ; ----- 1: integer add A=A+1, N times (16-bit accumulator in WK_*) ------------
000045r 1               op_int_add:
000045r 1  A9 00                lda     #0
000047r 1  8D rr rr             sta     wk_nlo
00004Ar 1  8D rr rr             sta     wk_nhi
00004Dr 1  AD rr rr             lda     param_nlo
