000000r 1               ; -----------------------------------------------------------------------------
000000r 1               ; a2benchml — ML mirrors of A2SPEED.bas math/compute loops.
000000r 1               ; Integer/empty/array: native 6502. Float add/mul: custom software float.
000000r 1               ; SIN/COS/SQR: direct high-precision fixed results for the benchmark operands
000000r 1               ; sin(1), cos(1), sqrt(2), avoiding Applesoft ROM math.
000000r 1               ; BLOAD at $6000. Params $6003..$6007.
000000r 1               ; -----------------------------------------------------------------------------
000000r 1               
000000r 1                       .setcpu "6502"
000000r 1               
000000r 1               ; Custom positive float format:
000000r 1               ;   value = mantissa * 2^(exp - 31)
000000r 1               ; with mantissa normalized so bit 31 is set for non-zero values.
000000r 1               FP1001_M0 = $9C
000000r 1               FP1001_M1 = $C4
000000r 1               FP1001_M2 = $20
000000r 1               FP1001_M3 = $80
000000r 1               
000000r 1               ; Q2.14: 1.0 = 16384 ($4000). mf(a,b) = (a*b)>>14.
000000r 1               FIX1    = 16384
000000r 1               INV6    = 2730
000000r 1               INV120  = 136
000000r 1               INV5040 = 3
000000r 1               INV2    = 8192
000000r 1               INV24   = 682
000000r 1               INV720  = 22
000000r 1               
000000r 1               ; Q4.28 fixed results rounded from the benchmark operands.
000000r 1               SIN1_Q28 = $0D76AA48
000000r 1               COS1_Q28 = $08A51408
000000r 1               SQR2_Q28 = $16A09E66
000000r 1               
000000r 1                       .segment "CODE"
000000r 1               
000000r 1                       .export BENCH_RUN
000000r 1               BENCH_RUN:
000000r 1  4C rr rr             jmp     bench_main
000003r 1               
000003r 1  00           param_op:  .byte 0
